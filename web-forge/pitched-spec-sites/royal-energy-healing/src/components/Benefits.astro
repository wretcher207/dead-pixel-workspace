<section id="benefits" class="section relative">
  <div class="section-inner">
    <div class="text-center mb-12 reveal">
      <h2 class="text-neutral">What Shifts</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-10">
      <div class="reveal reveal-delay-1 text-center sm:text-left">
        <div class="w-px h-8 bg-accent/30 mx-auto sm:mx-0 mb-5"></div>
        <h3 class="text-neutral mb-2">Deep Relaxation</h3>
        <p class="text-neutral-dim text-sm leading-relaxed">
          Release the tension you have been holding and settle into a state of genuine calm.
        </p>
      </div>

      <div class="reveal reveal-delay-2 text-center sm:text-left">
        <div class="w-px h-8 bg-secondary/30 mx-auto sm:mx-0 mb-5"></div>
        <h3 class="text-neutral mb-2">Emotional Release</h3>
        <p class="text-neutral-dim text-sm leading-relaxed">
          Let go of what no longer serves you and create space for what does.
        </p>
      </div>

      <div class="reveal reveal-delay-3 text-center sm:text-left">
        <div class="w-px h-8 bg-accent/30 mx-auto sm:mx-0 mb-5"></div>
        <h3 class="text-neutral mb-2">Clarity & Focus</h3>
        <p class="text-neutral-dim text-sm leading-relaxed">
          Quiet the noise so you can hear your own thinking again.
        </p>
      </div>

      <div class="reveal reveal-delay-4 text-center sm:text-left">
        <div class="w-px h-8 bg-secondary/30 mx-auto sm:mx-0 mb-5"></div>
        <h3 class="text-neutral mb-2">Spiritual Connection</h3>
        <p class="text-neutral-dim text-sm leading-relaxed">
          Strengthen your relationship with yourself at the most fundamental level.
        </p>
      </div>
    </div>
  </div>
</section>
