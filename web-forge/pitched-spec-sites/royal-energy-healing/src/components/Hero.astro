---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <div class="hero-bg absolute inset-0" aria-hidden="true">
    <div class="hero-glow hero-glow--a"></div>
    <div class="hero-glow--b"></div>
  </div>

  <div class="grain absolute inset-0 pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 text-center px-6 w-full max-w-2xl mx-auto">
    <p class="text-accent/70 text-xs tracking-[0.25em] uppercase mb-10 font-medium">
      Newport, Maine
    </p>

    <h1 class="text-neutral mb-8">
      Royal Energy<br />Healing Experience
    </h1>

    <p class="font-heading text-lg sm:text-xl text-secondary/80 italic font-light mb-6">
      Still your mind. Restore your energy.
    </p>

    <p class="text-neutral-dim text-sm sm:text-base max-w-md mx-auto mb-14 leading-relaxed">
      Healing begins when you slow down long enough to listen. This is your space to return to center.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-5">
      <a href="#booking" class="btn-primary">Book Your Session</a>
      <a href="#services" class="btn-secondary">Explore Services</a>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-foundation-dark to-transparent z-10 pointer-events-none" aria-hidden="true"></div>
</section>

<style>
  .hero-bg {
    background: var(--color-foundation-dark);
  }

  .hero-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
  }

  .hero-glow--a {
    width: 50vw;
    max-width: 600px;
    aspect-ratio: 1;
    top: 15%;
    left: 10%;
    background: radial-gradient(circle, oklch(0.55 0.1 290 / 0.2) 0%, transparent 70%);
    animation: drift 20s ease-in-out infinite;
  }

  .hero-glow--b {
    position: absolute;
    width: 40vw;
    max-width: 450px;
    aspect-ratio: 1;
    border-radius: 50%;
    bottom: 10%;
    right: 8%;
    background: radial-gradient(circle, oklch(0.65 0.08 65 / 0.12) 0%, transparent 70%);
    filter: blur(100px);
    animation: drift 24s ease-in-out infinite reverse;
  }

  @keyframes drift {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(12px, -15px); }
  }
</style>
