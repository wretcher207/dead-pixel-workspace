---
---

<section id="connect" class="section relative">
  <div class="section-inner">
    <div class="text-center mb-14 reveal">
      <h2 class="text-neutral">Get In Tune...</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-12 items-start">
      <!-- Instagram embed -->
      <div class="lg:col-span-3 reveal reveal-delay-1">
        <div class="instagram-wrapper rounded-xl overflow-hidden">
          <blockquote class="instagram-media" data-instgrm-permalink="https://www.instagram.com/royalenergyhealingexperience/?utm_source=ig_embed&utm_campaign=loading" data-instgrm-version="14" style="background:#FFF; border:0; border-radius:3px; box-shadow:0 0 1px 0 rgba(0,0,0,0.5),0 1px 10px 0 rgba(0,0,0,0.15); margin: 0; max-width:540px; min-width:326px; padding:0; width:100%;"></blockquote>
        </div>
      </div>

      <!-- Other platforms -->
      <div class="lg:col-span-2 reveal reveal-delay-2 space-y-5">
        <!-- YouTube -->
        <a href="https://www.youtube.com/@TheEclecticWitchTarotShow" target="_blank" rel="noopener noreferrer" class="channel-link group block relative p-6 rounded-xl overflow-hidden">
          <div class="channel-bg channel-bg--yt absolute inset-0" aria-hidden="true"></div>
          <div class="relative z-10">
            <div class="flex items-center justify-between mb-3">
              <svg class="w-5 h-5 text-neutral/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="4" /><polygon points="10,8 16,12 10,16" /></svg>
              <svg class="w-4 h-4 text-neutral/30 group-hover:text-neutral/60 group-hover:translate-x-0.5 transition-all" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M5 3l6 5-6 5" /></svg>
            </div>
            <p class="font-heading text-neutral text-base mb-1">The Eclectic Witch Tarot Show</p>
            <p class="text-neutral-dim text-xs">Readings, guidance & energy talk on YouTube</p>
          </div>
        </a>

        <!-- TikTok -->
        <a href="https://www.tiktok.com/@eclecticwitchtarot" target="_blank" rel="noopener noreferrer" class="channel-link group block relative p-6 rounded-xl overflow-hidden">
          <div class="channel-bg channel-bg--tt absolute inset-0" aria-hidden="true"></div>
          <div class="relative z-10">
            <div class="flex items-center justify-between mb-3">
              <svg class="w-5 h-5 text-neutral/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5" /></svg>
              <svg class="w-4 h-4 text-neutral/30 group-hover:text-neutral/60 group-hover:translate-x-0.5 transition-all" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M5 3l6 5-6 5" /></svg>
            </div>
            <p class="font-heading text-neutral text-base mb-1">@eclecticwitchtarot</p>
            <p class="text-neutral-dim text-xs">Quick pulls & energy updates on TikTok</p>
          </div>
        </a>

        <!-- Instagram -->
        <a href="https://www.instagram.com/royalenergyhealingexperience/" target="_blank" rel="noopener noreferrer" class="channel-link group block relative p-6 rounded-xl overflow-hidden">
          <div class="channel-bg channel-bg--ig absolute inset-0" aria-hidden="true"></div>
          <div class="relative z-10">
            <div class="flex items-center justify-between mb-3">
              <svg class="w-5 h-5 text-neutral/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" /><circle cx="12" cy="12" r="5" /><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" /></svg>
              <svg class="w-4 h-4 text-neutral/30 group-hover:text-neutral/60 group-hover:translate-x-0.5 transition-all" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M5 3l6 5-6 5" /></svg>
            </div>
            <p class="font-heading text-neutral text-base mb-1">Royal Energy Healing</p>
            <p class="text-neutral-dim text-xs">Sessions, behind-the-scenes & client stories</p>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>

<script async src="//www.instagram.com/embed.js"></script>

<style>
  .channel-link {
    border: 1px solid oklch(0.65 0.08 280 / 0.1);
    transition: border-color 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .channel-link:hover {
    border-color: oklch(0.65 0.08 280 / 0.3);
    transform: translateY(-2px);
  }

  .channel-bg {
    opacity: 0.06;
    transition: opacity 0.4s ease;
  }

  .channel-link:hover .channel-bg {
    opacity: 0.1;
  }

  .channel-bg--yt {
    background: linear-gradient(135deg, #ff0000 0%, transparent 60%);
  }

  .channel-bg--tt {
    background: linear-gradient(135deg, #00f2ea 0%, #ff0050 50%, transparent 80%);
  }

  .channel-bg--ig {
    background: linear-gradient(135deg, #f09433 0%, #dc2743 30%, #bc1888 60%, transparent 80%);
  }
</style>
