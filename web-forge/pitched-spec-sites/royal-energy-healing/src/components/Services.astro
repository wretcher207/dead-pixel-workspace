<section id="services" class="section relative">
  <div class="section-inner">
    <div class="text-center mb-14 reveal">
      <h2 class="text-neutral">Our Offerings</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 sm:gap-8">
      <div class="reveal reveal-delay-1">
        <div class="glass service-card group p-8 sm:p-10 h-full">
          <h3 class="text-neutral mb-4">Reiki Healing</h3>
          <p class="text-neutral-dim text-sm sm:text-base leading-relaxed">
            Gentle, hands-on energy work that releases tension stored deep in the body. You leave lighter, calmer, and more aligned with yourself.
          </p>
        </div>
      </div>

      <div class="reveal reveal-delay-2">
        <div class="glass service-card group p-8 sm:p-10 h-full">
          <h3 class="text-neutral mb-4">Energy Alignment</h3>
          <p class="text-neutral-dim text-sm sm:text-base leading-relaxed">
            A focused session to identify and correct imbalances in your energy field. Recalibrate your system and reconnect with your natural state of equilibrium.
          </p>
        </div>
      </div>

      <div class="reveal reveal-delay-3">
        <div class="glass service-card group p-8 sm:p-10 h-full">
          <h3 class="text-neutral mb-4">Tarot & Oracle Readings</h3>
          <p class="text-neutral-dim text-sm sm:text-base leading-relaxed">
            Intuitive card readings that bring clarity to the questions you carry. Gain honest perspective and grounded insight for the road ahead.
          </p>
        </div>
      </div>

      <div class="reveal reveal-delay-4">
        <div class="glass service-card group p-8 sm:p-10 h-full">
          <h3 class="text-neutral mb-4">Distance Healing</h3>
          <p class="text-neutral-dim text-sm sm:text-base leading-relaxed">
            Full Reiki sessions conducted remotely with the same depth and intention. Receive powerful energy work from wherever you are.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .service-card {
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
  }

  .service-card:hover {
    border-color: oklch(0.65 0.08 280 / 0.35);
    box-shadow: 0 4px 24px oklch(0.2 0.05 280 / 0.2);
  }
</style>
