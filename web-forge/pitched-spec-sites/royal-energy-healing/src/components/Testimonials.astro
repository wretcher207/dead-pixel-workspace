<section id="testimonials" class="section relative">
  <div class="section-inner">
    <div class="text-center mb-12 reveal">
      <h2 class="text-neutral">What People Say</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      <div class="reveal reveal-delay-1">
        <blockquote class="testimonial-card p-7 sm:p-8 h-full flex flex-col">
          <p class="font-heading text-neutral/90 text-base sm:text-lg italic font-light leading-relaxed mb-6 flex-grow">
            &ldquo;I walked in wound tight and left feeling like I had finally set something down. Jill has an incredible ability to read what you need without you saying a word.&rdquo;
          </p>
          <cite class="text-neutral-dim text-sm not-italic">
            Sarah M. &mdash; Bangor
          </cite>
        </blockquote>
      </div>

      <div class="reveal reveal-delay-2">
        <blockquote class="testimonial-card p-7 sm:p-8 h-full flex flex-col">
          <p class="font-heading text-neutral/90 text-base sm:text-lg italic font-light leading-relaxed mb-6 flex-grow">
            &ldquo;I was skeptical, honestly. But twenty minutes in, something shifted. I slept through the night for the first time in months.&rdquo;
          </p>
          <cite class="text-neutral-dim text-sm not-italic">
            Tom R. &mdash; Waterville
          </cite>
        </blockquote>
      </div>

      <div class="reveal reveal-delay-3">
        <blockquote class="testimonial-card p-7 sm:p-8 h-full flex flex-col">
          <p class="font-heading text-neutral/90 text-base sm:text-lg italic font-light leading-relaxed mb-6 flex-grow">
            &ldquo;Jill made me feel safe from the moment I sat down. The session was precise, calm, and I felt the difference for days afterward.&rdquo;
          </p>
          <cite class="text-neutral-dim text-sm not-italic">
            Rachel D. &mdash; Augusta
          </cite>
        </blockquote>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonial-card {
    border-left: 1px solid oklch(0.65 0.1 280 / 0.15);
    transition: border-color 0.4s ease;
  }

  .testimonial-card:hover {
    border-color: var(--color-secondary);
  }
</style>
